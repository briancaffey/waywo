# Hugging Face authentication token
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Path to Hugging Face cache directory on the host
# Leave empty to use container's internal cache (models download on first run)
# Or set to your existing HF cache directory, e.g.:
# HF_HOME_HOST=/home/username/.cache/huggingface
# HF_HOME_HOST=/home/username/d/huggingface
HF_HOME_HOST=
